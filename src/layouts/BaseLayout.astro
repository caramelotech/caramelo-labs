---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Caramelo Labs',
  description = 'Espaço de aprendizado prático da Caramelo Tech.',
} = Astro.props;

const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="icon" href={`${base}/favicon.svg`} type="image/svg+xml" />
  </head>
  <body>
    <header>
      <div class="container">
        <a href={`${base}/`} class="logo">Caramelo Labs</a>
        <nav>
          <a href={`${base}/`}>Artigos</a>
        </nav>
      </div>
    </header>

    <main class="container">
      <slot />
    </main>

    <footer>
      <div class="container">
        <p>© 2026 Caramelo Tech</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  *, *::before, *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  :root {
    --bg: #fdfaf5;
    --surface: #ffffff;
    --accent: #c47d2e;
    --accent-hover: #a3681f;
    --accent-light: #fef3e2;
    --text: #2d2017;
    --text-muted: #8a7060;
    --border: #e8ddd0;
    --tag-bg: #fef3e2;
    --tag-text: #a3681f;
    --shadow-hover: 0 4px 12px rgba(0,0,0,0.08), 0 8px 24px rgba(0,0,0,0.05);
    --radius: 12px;
    --radius-sm: 6px;
    --font-sans: system-ui, -apple-system, 'Segoe UI', sans-serif;
    --font-mono: 'Fira Code', 'Cascadia Code', ui-monospace, monospace;
  }

  html {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-sans);
    font-size: 16px;
    line-height: 1.6;
    scroll-behavior: smooth;
  }

  body {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
  }

  a {
    color: var(--accent);
    text-decoration: none;
  }

  a:hover {
    color: var(--accent-hover);
  }

  /* Layout */
  .container {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  /* Header */
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 1rem 0;
    position: sticky;
    top: 0;
    z-index: 10;
  }

  header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .logo {
    font-size: 1.1rem;
    font-weight: 800;
    color: var(--text);
    letter-spacing: -0.02em;
  }

  .logo:hover {
    color: var(--accent);
  }

  nav a {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
  }

  nav a:hover {
    color: var(--accent);
  }

  /* Main */
  main {
    flex: 1;
    padding: 2.5rem 1.5rem;
  }

  /* Footer */
  footer {
    border-top: 1px solid var(--border);
    padding: 1.5rem 0;
    text-align: center;
    color: var(--text-muted);
    font-size: 0.8rem;
  }

  /* Hero */
  .hero {
    margin-bottom: 2rem;
  }

  .hero h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.375rem;
  }

  .hero p {
    color: var(--text-muted);
    font-size: 1rem;
  }

  /* Search bar */
  .search-bar {
    margin-bottom: 1rem;
  }

  .search-bar input {
    width: 100%;
    max-width: 400px;
    padding: 0.5rem 0.875rem;
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    background: var(--surface);
    color: var(--text);
    font-size: 0.9rem;
    font-family: inherit;
    outline: none;
    transition: border-color 0.15s;
  }

  .search-bar input:focus {
    border-color: var(--accent);
  }

  .search-bar input::placeholder {
    color: var(--text-muted);
  }

  /* Tag filter */
  .tag-filter {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 2rem;
  }

  .tag-btn {
    padding: 0.35rem 0.875rem;
    border-radius: 999px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text-muted);
    font-size: 0.8rem;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.15s;
    font-family: inherit;
  }

  .tag-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }

  .tag-btn.active {
    background: var(--accent);
    border-color: var(--accent);
    color: #fff;
  }

  /* Articles grid */
  .articles-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
  }

  /* Card */
  .card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    transition: box-shadow 0.2s, transform 0.2s;
    overflow: hidden;
  }

  .card:hover {
    box-shadow: var(--shadow-hover);
    transform: translateY(-2px);
  }

  .card-link {
    display: block;
    color: inherit;
  }

  .card-content {
    padding: 1.375rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .card-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  .tag {
    display: inline-block;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    background: var(--tag-bg);
    color: var(--tag-text);
    font-size: 0.75rem;
    font-weight: 500;
  }

  a.tag:hover {
    background: var(--accent-light);
    color: var(--accent-hover);
  }

  .card-title {
    font-size: 1.05rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text);
    line-height: 1.3;
  }

  .card-description {
    color: var(--text-muted);
    font-size: 0.875rem;
    line-height: 1.5;
    flex: 1;
  }

  .card-date {
    color: var(--text-muted);
    font-size: 0.775rem;
    margin-top: 0.25rem;
  }

  /* Back link */
  .back-link {
    display: inline-block;
    color: var(--text-muted);
    font-size: 0.875rem;
    margin-bottom: 1.5rem;
  }

  .back-link:hover {
    color: var(--accent);
  }

  /* Article */
  .article-wrapper {
    max-width: 720px;
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-header h1 {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .article-meta {
    display: flex;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.75rem;
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
  }

  /* Article content */
  .article-content {
    line-height: 1.8;
    font-size: 1.05rem;
  }

  .article-content h1,
  .article-content h2,
  .article-content h3,
  .article-content h4 {
    font-weight: 700;
    letter-spacing: -0.02em;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
    color: var(--text);
    line-height: 1.3;
  }

  .article-content h2 { font-size: 1.4rem; }
  .article-content h3 { font-size: 1.15rem; }

  .article-content p {
    margin-bottom: 1.25rem;
  }

  .article-content ul,
  .article-content ol {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .article-content li {
    margin-bottom: 0.375rem;
  }

  .article-content code {
    background: var(--accent-light);
    color: var(--accent-hover);
    padding: 0.15em 0.4em;
    border-radius: var(--radius-sm);
    font-family: var(--font-mono);
    font-size: 0.875em;
  }

  .article-content pre {
    background: #2d2017;
    color: #fdf6ec;
    padding: 1.25rem;
    border-radius: var(--radius);
    overflow-x: auto;
    margin-bottom: 1.25rem;
  }

  .article-content pre code {
    background: none;
    color: inherit;
    padding: 0;
    font-size: 0.9rem;
  }

  .article-content blockquote {
    border-left: 3px solid var(--accent);
    padding-left: 1rem;
    color: var(--text-muted);
    margin-bottom: 1.25rem;
    font-style: italic;
  }

  .article-content table {
    width: 100%;
    border-collapse: collapse;
    margin-bottom: 1.25rem;
    font-size: 0.9rem;
  }

  .article-content th,
  .article-content td {
    padding: 0.625rem 0.875rem;
    border: 1px solid var(--border);
    text-align: left;
  }

  .article-content th {
    background: var(--accent-light);
    font-weight: 600;
  }

  .article-content a {
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  /* Tag page */
  .tag-page-header {
    margin-bottom: 2rem;
  }

  .tag-page-header h1 {
    font-size: 1.75rem;
    font-weight: 800;
    letter-spacing: -0.03em;
    margin-bottom: 0.375rem;
  }

  .tag-name {
    color: var(--accent);
  }

  .tag-page-header > p {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  /* Empty state */
  .empty {
    text-align: center;
    padding: 4rem 0;
    color: var(--text-muted);
  }

  /* Responsive */
  @media (max-width: 640px) {
    .hero h1 { font-size: 1.5rem; }
    .article-header h1 { font-size: 1.5rem; }
    .articles-grid { grid-template-columns: 1fr; }
  }
</style>
